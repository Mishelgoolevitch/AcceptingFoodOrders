@{
    ViewData["Title"] = "Панель управления администратора";
}

<div class="container-fluid my-4">
    <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Панель управления администратора</h2>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Общее количество заказов</h6>
                            <h2>@ViewBag.TotalOrders</h2>
                        </div>
                        <i class="bi bi-cart-check display-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Общее количество пользователей</h6>
                            <h2>@ViewBag.TotalUsers</h2>
                        </div>
                        <i class="bi bi-people display-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Пункты меню</h6>
                            <h2>@ViewBag.TotalItems</h2>
                        </div>
                        <i class="bi bi-menu-button-wide display-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header">
                    <h5>Быстрые действия</h5>
                </div>
                <div class="card-body">
                    <a href="/Admin/ManageMenu" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-menu-up"></i> Управление Меню
                    </a>
                    <a href="#" class="btn btn-outline-success w-100 mb-2">
                        <i class="bi bi-list-check"></i> Просмотр Заказов
                    </a>
                    <a href="#" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-shop"></i> Просмотр Сайта
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
